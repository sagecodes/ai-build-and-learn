# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Anthropic ─────────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase / pgvector ───────────────────────────────────────────────────
# Direct connection host from Supabase dashboard → Settings → Database
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=<your-supabase-password>

# ── Union / Flyte backend ─────────────────────────────────────────────────
# "union"  = run tasks on Union cluster (requires secrets registered in Union)
# "local"  = run tasks in-process (no Union needed, for development)
FLYTE_BACKEND=union
