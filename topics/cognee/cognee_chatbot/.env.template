# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Anthropic ─────────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase / pgvector ───────────────────────────────────────────────────
# Direct connection host from Supabase dashboard → Settings → Database
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=<your-supabase-password>

# ── Cognee mode ───────────────────────────────────────────────────────────
# Disable multi-tenant mode so Cognee uses a single shared DB (no CREATE DATABASE calls)
ENABLE_BACKEND_ACCESS_CONTROL=false

# ── Embeddings ───────────────────────────────────────────────────────────
# Local sentence-transformers — no OpenAI key required
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
COGNEE_SKIP_CONNECTION_TEST=true

# ── Union / Flyte backend ─────────────────────────────────────────────────
# "union"  = run tasks on Union cluster (requires secrets registered in Union)
# "local"  = run tasks in-process (no Union needed, for development)
FLYTE_BACKEND=union
