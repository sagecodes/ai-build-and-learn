# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Supabase / pgvector (Vector RAG) ──────────────────────────────────────────
# Use the Session Pooler URL (not direct — direct connection uses IPv6, which
# may be blocked). Find this in Supabase → Project Settings → Database → Connection string.
# Format: postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
PG_URL=postgresql://postgres.your-project-ref:your-password@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ── Neo4j AuraDB Free (Graph RAG) ─────────────────────────────────────────────
# URI format: neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Cognee local storage ──────────────────────────────────────────────────────
# Optional: override default storage location (.cognee_data/ in project root)
# COGNEE_DATA_PATH=/path/to/cognee/storage

# ── Google Vertex AI / Gemma 4 (Model Comparison tab) ────────────────────────
# Auth uses Application Default Credentials — no key file needed on GCP VM.
# VM service account must have roles/aiplatform.user granted in GCP IAM.
GCP_PROJECT=your-gcp-project-id
GCP_REGION=global
GEMMA_MODEL=publishers/google/models/gemma-4-26b-a4b-it-maas
