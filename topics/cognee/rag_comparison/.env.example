# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Supabase / pgvector (Vector RAG) ──────────────────────────────────────────
# Use the Session Pooler connection (not direct) — format:
#   Host: aws-1-us-east-1.pooler.supabase.com
#   User: postgres.<project-ref>
PG_HOST=your-supabase-pooler-host
PG_PORT=5432
PG_DB=postgres
PG_USER=postgres.your-project-ref
PG_PASSWORD=your-supabase-password

# ── Neo4j AuraDB Free (Graph RAG) ─────────────────────────────────────────────
# URI format: neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Cognee local storage ──────────────────────────────────────────────────────
# Optional: override default storage location (.cognee_data/ in project root)
# COGNEE_DATA_PATH=/path/to/cognee/storage
