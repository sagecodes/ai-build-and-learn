# Same variables as rag_comparison — no new secrets needed.
# Copy to .env and fill in values.

ANTHROPIC_API_KEY=sk-ant-...

# Supabase Session Pooler URL (IPv4 required — not the direct connection URL)
PG_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres

# Neo4j AuraDB
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Cognee local storage (Docker volume-mounted from host)
# COGNEE_DATA_PATH=/usr/local/lib/python3.11/site-packages/cognee/.cognee_system

# Google Vertex AI / Gemma (optional — only needed if running Gemma tab)
# GCP_PROJECT=
# GCP_REGION=global
# GEMMA_MODEL=publishers/google/models/gemma-4-26b-a4b-it-maas
