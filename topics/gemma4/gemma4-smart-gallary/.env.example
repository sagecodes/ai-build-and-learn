# Gemma 4 Smart Gallery — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ── Gemma 4 model (swap to gemma-4-31b-it-maas when confirmed MaaS) ──────────
GEMMA_MODEL=google/gemma-4-26b-a4b-it-maas

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=global

# ── Optional: path to service account JSON (if not using gcloud ADC) ─────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
