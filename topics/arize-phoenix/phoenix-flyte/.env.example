# Local-run convenience (python workflow.py). On the cluster these come from
# Flyte secrets instead (SAGE_OPENAI_API_KEY, TAVILY_API_KEY).
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Optional: switch the agent LLM to the in-cluster gemma4 vLLM app.
# LLM_PROVIDER=vllm

# For `flyte run --local` only: the in-cluster collector DNS is not reachable
# from your machine, so point at the host URL (Kourier on the devbox) and local
# spans still reach Phoenix. Remote runs ignore this (pods get the cluster
# endpoint injected). Needs the tracing libs locally too:
#   uv pip install arize-phoenix-otel openinference-instrumentation-langchain
# PHOENIX_COLLECTOR_ENDPOINT=http://phoenix-server-flytesnacks-development.localhost:30081
